---
import BaseLayout from "@/components/BaseLayout.astro";
import CardGrid from "@/components/CardGrid.astro";
import ProfileHome from "@/components/ProfileHome.astro";
import PortfolioSection from "@/components/PortfolioSection.astro";
import type { Locale, PageId } from "@/data/site";
import {
  aboutBlocks,
  credentials,
  getLocalizedPath,
  pageMeta,
} from "@/data/site";

type Props = Readonly<{
  locale: Locale;
  pageId: PageId;
}>;

const { locale, pageId } = Astro.props;
const page = pageMeta[pageId];
---

<BaseLayout locale={locale} pageId={pageId}>
  {
    pageId === "home" && (
      <ProfileHome locale={locale} />
    )
  }

  {
    pageId === "services" && (
      <PortfolioSection locale={locale} />
    )
  }

  {
    pageId === "about" && (
      <>
        <section class="page-heading page-heading--plain reveal">
          <h1>{page.title[locale]}</h1>
        </section>
        <section class="about-page">
          <p class="about-page__quote reveal">"DARE TO BREAKTHROUGH"</p>
          {aboutBlocks.map((block) => (
            <section class="about-block reveal">
              <h2>{block.eyebrow[locale]}</h2>
              <div class="about-block__columns">
                <div>
                  {block.vi.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
                <div>
                  {block.en.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
              </div>
            </section>
          ))}
        </section>
      </>
    )
  }

  {
    pageId === "credential" && (
      <>
        <section class="page-heading page-heading--credential reveal">
          <h1>{page.title[locale]}</h1>
        </section>
        <section class="content-section content-section--credential-list">
          <CardGrid items={credentials} locale={locale} variant="credential" />
        </section>
      </>
    )
  }

  {
    pageId === "contact" && (
      <>
        <section class="page-heading page-heading--contact reveal">
          <h1>{page.title[locale]}</h1>
          <p>{page.kicker[locale]}</p>
        </section>
        <section class="contact-page content-section reveal" aria-labelledby="contact-page-title">
          <div class="contact-page__intro">
            <p class="eyebrow">{locale === "vi" ? "BẮT ĐẦU MỘT DỰ ÁN" : "START A PROJECT"}</p>
            <h2 id="contact-page-title">
              {locale === "vi" ? "Bạn đang có một brief cần biến thành kế hoạch rõ ràng?" : "Have a brief that needs a clear delivery plan?"}
            </h2>
            <p>
              {locale === "vi"
                ? "Hãy xem các dự án đã chọn và gửi một brief ngắn để bắt đầu cuộc trao đổi phù hợp."
                : "Explore selected work, then share a short brief to start the right conversation."}
            </p>
          </div>
          <div class="contact-page__actions">
            <a class="profile-button profile-button--primary" href={getLocalizedPath(locale, "/services/")}>
              {locale === "vi" ? "Xem Portfolio" : "View Portfolio"}
            </a>
            <a class="profile-button" href={getLocalizedPath(locale, "/about/")}>
              {locale === "vi" ? "Tìm hiểu cách làm việc" : "See how I work"}
            </a>
          </div>
        </section>
      </>
    )
  }
</BaseLayout>
