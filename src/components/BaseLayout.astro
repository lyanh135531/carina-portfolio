---
import Header from "@/components/Header.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/global.scss";
import type { Locale, PageId } from "@/data/site";
import { pageMeta } from "@/data/site";

type Props = Readonly<{
  locale: Locale;
  pageId: PageId;
  title?: string;
  description?: string;
}>;

type FooterColumn = Readonly<{
  title: string;
  body: readonly string[];
}>;

type FooterContent = Readonly<{
  columns: readonly FooterColumn[];
  brandLine: string;
  legal: string;
}>;

const { locale, pageId, title, description } = Astro.props;
const meta = pageMeta[pageId];
const documentTitle = title ?? meta.title[locale];
const documentDescription = description ?? "Portfolio overview for an Account Executive and Producer profile.";
const socialImageUrl = new URL("/og.png", Astro.site ?? Astro.url).toString();
const footerContentByLocale: Readonly<Record<Locale, FooterContent>> = {
  vi: {
    columns: [
      {
        title: "Hồ sơ",
        body: ["Account Executive / Nhà sản xuất", "Quản lý khách hàng, bàn giao dự án và sản xuất sáng tạo."],
      },
      {
        title: "Trọng tâm",
        body: ["Điều phối chiến dịch sáng tạo", "Triển khai hệ thống SaaS", "Quy trình làm việc với đối tác và sản xuất"],
      },
      {
        title: "Phong cách làm việc",
        body: ["Yêu cầu rõ ràng, tiến độ rõ ràng, trách nhiệm rõ ràng.", "Được xây dựng để bàn giao hướng tới khách hàng."],
      },
    ],
    brandLine: "Hồ sơ năng lực Account Executive / Nhà sản xuất",
    legal: "Carina Portfolio",
  },
  en: {
    columns: [
      {
        title: "Profile",
        body: ["Account Executive / Producer", "Client management, project delivery and creative production."],
      },
      {
        title: "Focus",
        body: ["Creative campaign coordination", "SaaS implementation", "Production and vendor workflow"],
      },
      {
        title: "Working Style",
        body: ["Clear brief, clear timeline, clear ownership.", "Built for client-facing delivery."],
      },
    ],
    brandLine: "Account Executive / Producer Portfolio",
    legal: "Carina Portfolio",
  },
};
const footerContent = footerContentByLocale[locale];

---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={documentDescription}
    />
    <title>{documentTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.svg" />
    <meta name="theme-color" content="#fff7e8" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={documentDescription} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={documentDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght,SOFT,WONK@9..144,400..700,0..100,0..1&family=Nunito+Sans:opsz,wght@6..12,400..800&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body data-page={pageId}>
    <div class="scroll-progress" data-scroll-progress style="position: fixed; top: 0; left: 0; height: 3px; background: var(--color-yellow); z-index: 1000; width: 0%; transform-origin: 0 50%;"></div>
    <Header pageId={pageId} />
    <main>
      <slot />
    </main>
    <footer class="site-footer reveal">
      <div class="site-footer__columns">
        {
          footerContent.columns.map((column) => (
            <section>
              <h2>{column.title}</h2>
              <div class="site-footer__body">
                {
                  column.body.map((line) => (
                    <p>{line}</p>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
      <div class="site-footer__brand">
        <p class="site-footer__wordmark">Carina Portfolio</p>
        <p>{footerContent.brandLine}</p>
      </div>
      <p class="site-footer__legal">{footerContent.legal}</p>
    </footer>
    <script>
      import "@/scripts/animations";
    </script>
  </body>
</html>
