---
import Header from "@/components/Header.astro";
import { ClientRouter } from "astro:transitions";
import "@/styles/global.scss";
import type { Locale, PageId } from "@/data/site";
import { pageMeta } from "@/data/site";

type Props = Readonly<{
  locale: Locale;
  pageId: PageId;
  title?: string;
  description?: string;
  alternatePath?: string;
}>;

type FooterColumn = Readonly<{
  title: string;
  body: readonly string[];
}>;

type FooterContent = Readonly<{
  columns: readonly FooterColumn[];
  brandLine: string;
  legal: string;
}>;

const { locale, pageId, title, description, alternatePath } = Astro.props;
const meta = pageMeta[pageId];
const documentTitle = title ?? meta.title[locale];
const documentDescription = description ?? "Portfolio overview for an Account Executive and Producer profile.";
const footerContentByLocale: Readonly<Record<Locale, FooterContent>> = {
  vi: {
    columns: [
      {
        title: "Profile",
        body: ["Account Executive / Producer", "Client management, project delivery and creative production."],
      },
      {
        title: "Focus",
        body: ["Creative campaign coordination", "SaaS implementation", "Production and vendor workflow"],
      },
      {
        title: "Working Style",
        body: ["Clear brief, clear timeline, clear ownership.", "Built for client-facing delivery."],
      },
    ],
    brandLine: "Account Executive / Producer Portfolio",
    legal: "Carina Portfolio",
  },
  en: {
    columns: [
      {
        title: "Profile",
        body: ["Account Executive / Producer", "Client management, project delivery and creative production."],
      },
      {
        title: "Focus",
        body: ["Creative campaign coordination", "SaaS implementation", "Production and vendor workflow"],
      },
      {
        title: "Working Style",
        body: ["Clear brief, clear timeline, clear ownership.", "Built for client-facing delivery."],
      },
    ],
    brandLine: "Account Executive / Producer Portfolio",
    legal: "Carina Portfolio",
  },
};
const footerContent = footerContentByLocale[locale];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={documentDescription}
    />
    <title>{documentTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;700&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body data-page={pageId}>
    <div class="scroll-progress" data-scroll-progress style="position: fixed; top: 0; left: 0; height: 3px; background: #f7ee23; z-index: 1000; width: 0%; transform-origin: 0 50%;"></div>
    <Header locale={locale} pageId={pageId} alternatePath={alternatePath} />
    <main>
      <slot />
    </main>
    <footer class="site-footer reveal">
      <div class="site-footer__columns">
        {
          footerContent.columns.map((column) => (
            <section>
              <h2>{column.title}</h2>
              <div class="site-footer__body">
                {
                  column.body.map((line) => (
                    <p>{line}</p>
                  ))
                }
              </div>
            </section>
          ))
        }
      </div>
      <div class="site-footer__brand">
        <p class="site-footer__wordmark">Carina Portfolio</p>
        <p>{footerContent.brandLine}</p>
      </div>
      <p class="site-footer__legal">{footerContent.legal}</p>
    </footer>
    <script>
      import "@/scripts/animations";
    </script>
  </body>
</html>
