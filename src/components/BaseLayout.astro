---
import Header from "@/components/Header.astro";
import "@/styles/global.scss";
import type { Locale, PageId } from "@/data/site";
import { pageMeta } from "@/data/site";

type Props = Readonly<{
  locale: Locale;
  pageId: PageId;
  title?: string;
  description?: string;
  alternatePath?: string;
}>;

const { locale, pageId, title, description, alternatePath } = Astro.props;
const meta = pageMeta[pageId];
const documentTitle = title ?? meta.title[locale];
const documentDescription = description ?? "Private learning clone of the TRÒN portfolio interface.";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content={documentDescription}
    />
    <title>{documentTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;700&family=Varela+Round&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-page={pageId}>
    <Header locale={locale} pageId={pageId} alternatePath={alternatePath} />
    <main>
      <slot />
    </main>
    <footer class="site-footer reveal">
      <div class="site-footer__columns">
        <section>
          <h2>Headquarters</h2>
          <p>T11-21, Đường T11, Khu The Manhattan Glory, Vinhomes Grand Park, Phường Long Bình, Thủ Đức, Vietnam</p>
        </section>
        <section>
          <h2>Hotline</h2>
          <p>+8496.1934.065 -<br />+8428.7102.2407</p>
        </section>
        <section>
          <h2>Connect</h2>
          <div class="site-footer__social" aria-label="Social channels">
            <span>f</span>
            <span>ig</span>
            <span>yt</span>
            <span>p</span>
            <span>be</span>
          </div>
          <p>cs@tronhouse.com</p>
        </section>
      </div>
      <div class="site-footer__brand">
        <img src="/assets/tronhouse/home/logo-new-fb20d29dba.png" alt="TRÒN" />
        <p>TRÒN - Creative Solution For Businesses</p>
      </div>
      <p class="site-footer__legal">© All rights reserved. Made by TRÒN<br />tronhouse.com - tronhouse.vn</p>
    </footer>
    <script>
      import "@/scripts/animations";
    </script>
  </body>
</html>
