---
import type { ImageAsset, Locale, LocalizedText } from "@/data/site";
import { getLocalizedPath } from "@/data/site";

type CardItem = Readonly<{
  title: LocalizedText;
  image: ImageAsset;
  href?: string;
  disabled?: true;
}>;

type Props = Readonly<{
  items: readonly CardItem[];
  locale: Locale;
  variant: "service" | "credential";
}>;

const { items, locale, variant } = Astro.props;
---

<div class:list={["card-grid", `card-grid--${variant}`, "reveal"]}>
  {
    items.map((item) => {
      const itemHref = item.href && !item.disabled ? getLocalizedPath(locale, item.href) : null;

      return itemHref ? (
        <a class:list={["media-card", `media-card--${variant}`, "is-linked"]} href={itemHref}>
          <div class="media-card__image">
            <img src={item.image.src} alt={item.image.alt[locale]} loading="lazy" onerror="this.hidden=true; this.parentElement.classList.add('is-fallback')" />
            <span class="media-card__shine"></span>
          </div>
          <div class="media-card__body">
            <h3>{item.title[locale]}</h3>
          </div>
        </a>
      ) : (
        <article class:list={["media-card", `media-card--${variant}`, item.disabled && "is-disabled"]} aria-disabled={item.disabled ? "true" : undefined}>
          <div class="media-card__image">
            <img src={item.image.src} alt={item.image.alt[locale]} loading="lazy" onerror="this.hidden=true; this.parentElement.classList.add('is-fallback')" />
            <span class="media-card__shine"></span>
          </div>
          <div class="media-card__body">
            <h3>{item.title[locale]}</h3>
          </div>
        </article>
      );
    })
  }
</div>
