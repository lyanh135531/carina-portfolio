---
import type { Locale } from "@/data/site";
import { portfolioCategories, portfolioProjects } from "@/data/portfolio";

type Props = { locale: Locale };
const { locale } = Astro.props;

const projectsJson = JSON.stringify(portfolioProjects);
const categoriesJson = JSON.stringify(portfolioCategories);
---

<section class="portfolio reveal">
  <div class="header">
    <p class="eyebrow">SELECTED WORK • 2022–2026</p>
    <h1>Portfolio</h1>
    <p class="subtitle">Key Visual • Packaging • TVC • Activation • Event • Social</p>
  </div>

  <div class="controls">
    <div class="filters" data-filters>
      <button class="filter active" data-filter="all">All</button>
      {portfolioCategories.map(cat => (
        <button class="filter" data-filter={cat.id}>{cat.label[locale]}</button>
      ))}
    </div>
    <div class="search-wrapper">
      <input type="text" id="portfolio-search" placeholder={locale === 'vi' ? "Tìm kiếm dự án..." : "Search projects..."} />
      <span class="search-icon">🔍</span>
    </div>
    <div class="count" id="project-count"></div>
  </div>

  <div class="grid" data-grid>
    <div id="empty-state" class="empty-state" style="display: none;">
      <div class="empty-icon">📂</div>
      <h3>{locale === 'vi' ? 'Không tìm thấy dự án' : 'No projects found'}</h3>
      <p>{locale === 'vi' ? 'Thử điều chỉnh từ khóa hoặc bộ lọc của bạn.' : 'Try adjusting your search or filters.'}</p>
    </div>
    {portfolioProjects.map(p => (
      <article class="card" data-category={p.category} data-id={p.id}>
        <div class={`media media--${p.category}`}>
          <div class="skeleton-loader"></div>
          {p.thumbnail && p.thumbnail.endsWith('.mp4') ? (
            <video data-src={p.thumbnail} muted playsinline preload="none" loop class="card-video loading-media" onloadeddata="this.parentElement.classList.add('is-loaded')" />
          ) : p.thumbnail && !p.thumbnail.endsWith('.txt') ? (
            <img src={p.thumbnail} alt={p.title[locale]} loading="lazy" class="card-img loading-media" onload="this.parentElement.classList.add('is-loaded')" />
          ) : p.category === 'social' ? (
            <div class="social-media-preview loading-media" style="opacity: 1;">
              <span class="social-icon">📸</span>
              <span class="social-handle">@chinsu_usa</span>
            </div>
          ) : (
            <div class="media-placeholder loading-media" style="opacity: 1;">No preview</div>
          )}
          <div class="badge">{portfolioCategories.find(c => c.id === p.category)?.label[locale]}</div>
          {p.video && <div class="play-badge">▶ VIDEO</div>}
        </div>
        <div class="body">
          <div class="meta"><span>{p.year}</span> • <span>{p.client}</span></div>
          <h3>{p.title[locale]}</h3>
          <div class="tags">{p.tags.slice(0, 3).map(t => <span class="tag">{t}</span>)}</div>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- Sleek Slide-Over Drawer -->
<div class="drawer" id="drawer" aria-hidden="true">
  <div class="drawer-backdrop" data-close></div>
  <div class="drawer-panel">
    <button class="drawer-close" data-close>×</button>
    <div class="drawer-body-wrapper">
      <div class="drawer-content" id="drawer-content"></div>
      
      <div class="drawer-nav">
        <button class="nav-btn prev-btn" id="drawer-prev-btn">
          <span class="nav-arrow">←</span> 
          <div class="nav-details">
            <span class="nav-action">PREV</span>
            <span class="nav-title" id="drawer-prev-title">Project Title</span>
          </div>
        </button>
        <button class="nav-btn next-btn" id="drawer-next-btn">
          <div class="nav-details">
            <span class="nav-action">NEXT</span>
            <span class="nav-title" id="drawer-next-title">Project Title</span>
          </div>
          <span class="nav-arrow">→</span>
        </button>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ projectsJson, categoriesJson, locale }}>
  const projects = JSON.parse(projectsJson);
  const portfolioCategories = JSON.parse(categoriesJson);
  window.__PORTFOLIO__ = projects;

  function initPortfolio() {
    const grid = document.querySelector('[data-grid]');
    const filters = document.querySelectorAll('.filter');
    const searchInput = document.getElementById('portfolio-search');
    const countEl = document.getElementById('project-count');
    const drawer = document.getElementById('drawer');
    const drawerContent = document.getElementById('drawer-content');
    const prevBtn = document.getElementById('drawer-prev-btn');
    const nextBtn = document.getElementById('drawer-next-btn');
    const prevTitle = document.getElementById('drawer-prev-title');
    const nextTitle = document.getElementById('drawer-next-title');

    if (!grid) return;

    let activeProjects = [...projects];
    let currentProjectIndex = -1;

    // Update Project Count
    function updateCount(visible) {
      const total = projects.length;
      countEl.textContent = visible === total ? `${total} projects` : `${visible} / ${total} projects`;
    }
    updateCount(projects.length);

    // Apply Filtering & Searching
    function applyFilters() {
      const activeFilter = document.querySelector('.filter.active')?.dataset.filter || 'all';
      const searchTerm = (searchInput?.value || '').toLowerCase().trim();

      activeProjects = [];

      document.querySelectorAll('.card').forEach(card => {
        const cat = card.dataset.category;
        const id = card.dataset.id;
        const proj = projects.find(p => p.id === id) || {};
        const title = (proj.title?.[locale] || '').toLowerCase();
        const client = (proj.client || '').toLowerCase();

        const matchesFilter = activeFilter === 'all' || cat === activeFilter;
        const matchesSearch = !searchTerm || title.includes(searchTerm) || client.includes(searchTerm);

        if (matchesFilter && matchesSearch) {
          card.style.display = 'inline-flex';
          card.classList.add('visible-card');
          activeProjects.push(proj);
        } else {
          card.style.display = 'none';
          card.classList.remove('visible-card');
        }
      });
      updateCount(activeProjects.length);

      const emptyState = document.getElementById('empty-state');
      if (emptyState) {
        emptyState.style.display = activeProjects.length === 0 ? 'flex' : 'none';
      }
    }

    filters.forEach(f => f.addEventListener('click', () => {
      filters.forEach(x => x.classList.remove('active'));
      f.classList.add('active');
      applyFilters();
    }));

    let debounceTimer;
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          applyFilters();
        }, 300);
      });
    }

    // Intersection Observer for Lazy Loading Videos with Skeleton & Mobile Autoplay
    const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        const card = entry.target;
        const video = card.querySelector('.card-video');
        if (!video) return;

        if (entry.isIntersecting) {
          if (!video.src) {
            // Assign src to start loading metadata/first frame for the skeleton to finish
            video.src = video.dataset.src;
            video.load(); // Kích hoạt tải
          }
          // On mobile, auto-play when in viewport
          if (isTouchDevice) {
            video.play().catch(e => console.warn("Auto-play prevented", e));
          }
        } else {
          // Pause when out of viewport to save CPU
          video.pause();
        }
      });
    }, { rootMargin: '50px' });

    // Hover Video Playback Behavior & Observe
    document.querySelectorAll('.card').forEach(card => {
      observer.observe(card); // Theo dõi card để lazy load và quản lý playback
      
      const video = card.querySelector('.card-video');
      if (video && !isTouchDevice) {
        card.addEventListener('mouseenter', () => {
          // Fallback in case hover happens before IntersectionObserver triggers
          if (!video.src || video.getAttribute('src') === '') {
            video.src = video.dataset.src;
          }
          video.play().catch(e => {
            console.warn("Auto-play prevented or loading", e);
          });
        });
        card.addEventListener('mouseleave', () => {
          video.pause();
        });
      }

      // Card click to open drawer
      card.addEventListener('click', () => {
        const id = card.dataset.id;
        currentProjectIndex = activeProjects.findIndex(p => p.id === id);
        if (currentProjectIndex !== -1) {
          openDrawer(activeProjects[currentProjectIndex]);
        }
      });
    });

    // Drawer Open and Render Logic
    function openDrawer(proj) {
      if (!proj) return;

      const catLabel = portfolioCategories.find(c => c.id === proj.category)?.label[locale] || proj.category;

      // Media content
      let mediaHTML = '';
      if (proj.id === 'chinsu-social') {
        mediaHTML = `
          <div class="main-media social-embed-container">
            <div class="instagram-banner">
              <div class="insta-logo">📸</div>
              <h3>Chinsu USA</h3>
              <p class="insta-sub">Official Instagram Channel</p>
              <a href="https://www.instagram.com/chinsu_usa/" target="_blank" rel="noopener noreferrer" class="insta-btn">
                Visit @chinsu_usa →
              </a>
            </div>
          </div>
        `;
      } else if (proj.video) {
        mediaHTML = `
          <div class="main-media">
            <video src="${proj.video}" controls playsinline autoplay style="width:100%; max-height:480px; border-radius:16px; background:#000; display:block;"></video>
          </div>
        `;
      } else if (proj.thumbnail && !proj.thumbnail.endsWith('.txt')) {
        mediaHTML = `
          <div class="main-media">
            <img src="${proj.thumbnail}" alt="${proj.title[locale]}" style="width:100%; max-height:480px; object-fit:contain; border-radius:16px; display:block; margin:0 auto;" />
          </div>
        `;
      } else {
        mediaHTML = `<div class="main-media placeholder">No main visual</div>`;
      }

      // Gallery strip block (only show if there's more than 1 asset to avoid duplicates)
      let galleryHTML = '';
      if (proj.gallery && proj.gallery.length > 0) {
        const uniqueGallery = [...new Set(proj.gallery)];
        if (uniqueGallery.length > 1) {
          galleryHTML = `
            <div class="gallery-strip">
              <div class="gallery-thumbs">
                ${uniqueGallery.map((src, idx) => {
                  const isVideo = src.endsWith('.mp4');
                  const activeClass = (src === proj.thumbnail) ? 'active' : '';
                  return isVideo 
                    ? `<div class="thumb video-thumb ${activeClass}" data-src="${src}" data-type="video"><span>▶</span></div>`
                    : `<img class="thumb ${activeClass}" src="${src}" data-src="${src}" data-type="image" alt="Asset ${idx+1}" />`;
                }).join('')}
              </div>
            </div>
          `;
        }
      }

      // Project Brief section
      let briefHTML = '';
      if (proj.brief && proj.brief[locale]) {
        briefHTML = `
          <div class="brief-section">
            <div class="brief-label">🎯 Project Brief</div>
            <div class="brief-content">
              ${proj.brief[locale].split('\n').map(line => line.trim() ? `<p>${line}</p>` : '<br>').join('')}
            </div>
          </div>
        `;
      } else {
        briefHTML = `
          <div class="brief-section">
            <div class="brief-label">🎯 Project Brief</div>
            <div class="brief-content"><p class="empty-brief">No detailed project parameters provided.</p></div>
          </div>
        `;
      }

      // Populate drawer content
      drawerContent.innerHTML = `
        <div class="drawer-header">
          <div class="m-badges">
            <span class="m-badge">${catLabel}</span>
            ${proj.video ? '<span class="m-badge video">VIDEO</span>' : ''}
          </div>
          <h2>${proj.title[locale]}</h2>
          
          <div class="m-meta-grid">
            <div class="meta-card">
              <span class="meta-label">Client</span>
              <span class="meta-val">${proj.client}</span>
            </div>
            <div class="meta-card">
              <span class="meta-label">Year</span>
              <span class="meta-val">${proj.year}</span>
            </div>
            <div class="meta-card">
              <span class="meta-label">Type</span>
              <span class="meta-val">${catLabel}</span>
            </div>
          </div>
        </div>

        <div class="drawer-visuals">
          ${mediaHTML}
          ${galleryHTML}
        </div>

        <div class="drawer-details">
          <div class="m-section">
            <div class="m-section-title">📄 Overview</div>
            <p class="m-desc">${proj.description[locale]}</p>
          </div>

          ${briefHTML}

          <div class="m-section">
            <div class="m-section-title">🏷️ Project Tags</div>
            <div class="m-tags">
              ${proj.tags.map(t => `<span class="tag">${t}</span>`).join('')}
            </div>
          </div>
        </div>
      `;

      // Update In-drawer navigation state
      updateDrawerNavigation();

      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';

      // Gallery thumbnail click handler
      setTimeout(() => {
        const mainMedia = drawerContent.querySelector('.main-media');
        const thumbs = drawerContent.querySelectorAll('.thumb');
        thumbs.forEach(thumb => {
          thumb.addEventListener('click', () => {
            thumbs.forEach(t => t.classList.remove('active'));
            thumb.classList.add('active');

            const src = thumb.dataset.src;
            const type = thumb.dataset.type;
            if (!mainMedia || !src) return;

            if (type === 'video') {
              mainMedia.innerHTML = `<video src="${src}" controls playsinline autoplay style="width:100%; max-height:480px; border-radius:16px; background:#000; display:block;"></video>`;
            } else {
              mainMedia.innerHTML = `<img src="${src}" alt="Preview" style="width:100%; max-height:480px; object-fit:contain; border-radius:16px; display:block; margin:0 auto;" />`;
            }
          });
        });
      }, 50);
    }

    // Update Next/Prev Project Navigation in Drawer
    function updateDrawerNavigation() {
      // Prev Button
      if (currentProjectIndex > 0) {
        prevBtn.removeAttribute('disabled');
        const prevProj = activeProjects[currentProjectIndex - 1];
        prevTitle.textContent = prevProj.title[locale];
      } else {
        prevBtn.setAttribute('disabled', 'true');
        prevTitle.textContent = '---';
      }

      // Next Button
      if (currentProjectIndex < activeProjects.length - 1) {
        nextBtn.removeAttribute('disabled');
        const nextProj = activeProjects[currentProjectIndex + 1];
        nextTitle.textContent = nextProj.title[locale];
      } else {
        nextBtn.setAttribute('disabled', 'true');
        nextTitle.textContent = '---';
      }
    }

    // Nav Click Handlers
    prevBtn.addEventListener('click', () => {
      if (currentProjectIndex > 0) {
        currentProjectIndex--;
        // Fade effect transitions inside drawer panel
        drawerContent.style.opacity = '0';
        drawerContent.style.transform = 'translateY(15px)';
        setTimeout(() => {
          openDrawer(activeProjects[currentProjectIndex]);
          drawerContent.style.opacity = '1';
          drawerContent.style.transform = 'translateY(0)';
          drawerContent.scrollIntoView({ behavior: 'smooth' });
        }, 150);
      }
    });

    nextBtn.addEventListener('click', () => {
      if (currentProjectIndex < activeProjects.length - 1) {
        currentProjectIndex++;
        drawerContent.style.opacity = '0';
        drawerContent.style.transform = 'translateY(15px)';
        setTimeout(() => {
          openDrawer(activeProjects[currentProjectIndex]);
          drawerContent.style.opacity = '1';
          drawerContent.style.transform = 'translateY(0)';
          drawerContent.scrollIntoView({ behavior: 'smooth' });
        }, 150);
      }
    });

    // Close Actions
    document.querySelectorAll('[data-close]').forEach(el => el.addEventListener('click', () => {
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      const activeVideo = drawerContent.querySelector('video');
      if (activeVideo) {
        activeVideo.pause();
        activeVideo.removeAttribute('src'); // Giải phóng hoàn toàn RAM của video
        activeVideo.load();
      }
    }));

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && drawer.getAttribute('aria-hidden') === 'false') {
        drawer.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        const activeVideo = drawerContent.querySelector('video');
        if (activeVideo) {
          activeVideo.pause();
          activeVideo.removeAttribute('src');
          activeVideo.load();
        }
      }
    });
  }

  document.readyState === 'loading' 
    ? document.addEventListener('DOMContentLoaded', initPortfolio) 
    : initPortfolio();
</script>

<style>
  .portfolio {
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 24px 120px;
  }

  .header {
    text-align: center;
    margin-bottom: 60px;
  }

  .eyebrow {
    font-size: 11px;
    letter-spacing: 3px;
    color: var(--color-yellow);
    font-weight: 700;
    text-transform: uppercase;
  }

  .header h1 {
    font-family: var(--font-display);
    font-size: 56px;
    font-weight: 700;
    margin: 12px 0 16px;
    color: var(--color-white);
    letter-spacing: -1px;
  }

  .subtitle {
    color: var(--color-muted);
    font-size: 16px;
    opacity: 0.8;
  }

  /* Controls & Search */
  .controls {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
    margin-bottom: 40px;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 16px 24px;
    border-radius: 20px;
    backdrop-filter: blur(10px);
  }

  .filters {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .filter {
    padding: 8px 18px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    color: var(--color-muted);
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .filter:hover {
    color: var(--color-white);
    border-color: rgba(255, 255, 255, 0.2);
    background: rgba(255, 255, 255, 0.06);
    transform: translateY(-1px);
  }

  .filter.active {
    background: var(--color-yellow);
    color: var(--color-black);
    border-color: var(--color-yellow);
    box-shadow: 0 4px 15px rgba(255, 241, 0, 0.35);
  }

  .search-wrapper {
    position: relative;
    flex: 1;
    max-width: 320px;
  }

  #portfolio-search {
    width: 100%;
    padding: 10px 18px 10px 42px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    font-size: 14px;
    color: var(--color-white);
    transition: all 0.3s ease;
  }

  #portfolio-search::placeholder {
    color: var(--color-muted);
    opacity: 0.5;
  }

  #portfolio-search:focus {
    outline: none;
    border-color: var(--color-yellow);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 15px rgba(255, 241, 0, 0.2);
  }

  .search-icon {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    opacity: 0.5;
    pointer-events: none;
  }

  .count {
    font-size: 13.5px;
    color: var(--color-muted);
    opacity: 0.7;
    margin-left: auto;
    white-space: nowrap;
  }

  /* Masonry Grid via CSS Columns (No Gaps, High Performance) */
  .grid {
    column-count: 3;
    column-gap: 30px;
    width: 100%;
  }

  .empty-state {
    column-span: all;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 60px 20px;
    text-align: center;
    background: rgba(255, 255, 255, 0.02);
    border: 1px dashed rgba(255, 255, 255, 0.1);
    border-radius: 24px;
    width: 100%;
    margin-bottom: 30px;
  }

  .empty-icon {
    font-size: 48px;
    margin-bottom: 16px;
    opacity: 0.5;
  }

  .empty-state h3 {
    font-size: 20px;
    color: var(--color-white);
    margin: 0 0 8px;
  }

  .empty-state p {
    color: var(--color-muted);
    font-size: 14px;
    margin: 0;
  }

  .card {
    break-inside: avoid;
    display: inline-flex;
    flex-direction: column;
    width: 100%;
    margin-bottom: 30px;
    background: var(--color-panel-soft);
    border-radius: 24px;
    overflow: hidden;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid rgba(255, 255, 255, 0.05);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
    will-change: transform, box-shadow;
  }

  .card:hover {
    transform: translateY(-8px) scale(1.01);
    border-color: rgba(255, 241, 0, 0.3);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(255, 241, 0, 0.08);
  }

  .media {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--color-panel);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Skeleton Loader Styles */
  .skeleton-loader {
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.03) 25%, rgba(255, 255, 255, 0.08) 50%, rgba(255, 255, 255, 0.03) 75%);
    background-size: 400% 100%;
    animation: skeleton-loading 1.5s infinite ease-in-out;
    z-index: 2;
    transition: opacity 0.5s ease;
  }

  @keyframes skeleton-loading {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  .media.is-loaded .skeleton-loader {
    opacity: 0;
    pointer-events: none;
  }

  .loading-media {
    opacity: 0;
    transition: opacity 0.6s ease, transform 0.8s cubic-bezier(0.16, 1, 0.3, 1) !important;
  }

  .media.is-loaded .loading-media {
    opacity: 1;
  }

  /* Responsive Aspect Ratios depending on Content Category to create Masonry effect */
  .media--tvc { aspect-ratio: 16/9; }
  .media--key_visual { aspect-ratio: 4/3; }
  .media--bao_bi { aspect-ratio: 1/1; }
  .media--event { aspect-ratio: 3/2; }
  .media--social { aspect-ratio: 1/1; }
  .media--activation { aspect-ratio: 4/3; }

  .media img, .media video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .card:hover .media img, .card:hover .media video {
    transform: scale(1.05);
  }

  .media-placeholder {
    color: #666;
    font-size: 13px;
  }

  .badge {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(0, 0, 0, 0.7);
    color: var(--color-white);
    backdrop-filter: blur(8px);
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 1;
  }

  .play-badge {
    position: absolute;
    bottom: 20px;
    right: 20px;
    background: var(--color-yellow);
    color: var(--color-black);
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.5px;
    box-shadow: 0 3px 10px rgba(255, 241, 0, 0.3);
    z-index: 1;
  }

  .body {
