---
import type { PageId } from "@/data/site";
import { navigationItems } from "@/data/site";

type Props = Readonly<{
  pageId: PageId;
}>;

const { pageId } = Astro.props;
---

<header class="site-header" data-header>
  <a class="site-header__logo" href="/" aria-label="Trang chủ portfolio Carina">
    <span>Carina</span>
  </a>
  <button
    class="site-header__toggle"
    type="button"
    aria-label="Mở menu"
    aria-expanded="false"
    aria-controls="primary-navigation"
    data-menu-toggle
  >
    <span></span>
    <span></span>
  </button>
  <nav id="primary-navigation" class="site-header__nav" data-nav aria-label="Điều hướng chính">
    {
      navigationItems.map((item) => (
        <a
          class:list={["site-header__link", item.pageId === pageId && "is-active"]}
          href={item.path}
        >
          {item.label.vi}
        </a>
      ))
    }
  </nav>
</header>
